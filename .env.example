# AAP Gateway
AAP_HOSTNAME=https://aaponprem.chrislab.dev
AAP_TOKEN=
AAP_VALIDATE_CERTS=false

# iDRAC
IDRAC_PASSWORD=

# T620 post-provision SSH (optional — defaults to ~/.ssh/id_rsa)
# T620_SSH_KEY_PATH=~/.ssh/id_rsa

# Custom Execution Environment image (optional — build with ansible-builder)
# CUSTOM_EE_IMAGE=quay.io/crenwick93/bmaas-ee:latest

# Git repo URL (optional — defaults to https://github.com/crenwick93/aap-bmaas.git)
# GIT_REPO_URL=https://github.com/crenwick93/aap-bmaas.git
